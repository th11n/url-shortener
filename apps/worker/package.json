{
	"name": "worker",
	"type": "module",
	"main": "src/index.ts",
	"scripts": {
		"build": "tsdown",
		"check-types": "tsc -b",
		"compile": "bun build --compile --minify --sourcemap --bytecode ./src/index.ts --outfile worker",
		"dev": "bun run --hot src/index.ts",
		"start": "bun run dist/index.mjs"
	},
	"dependencies": {
		"@url-shortener/db": "workspace:*",
		"amqplib": "^0.10.9",
		"dotenv": "catalog:",
		"drizzle-orm": "^0.45.1",
		"isbot": "^5.1.34",
		"ua-parser-js": "^2.0.9",
		"zod": "catalog:"
	},
	"devDependencies": {
		"@types/amqplib": "^0.10.7",
		"@types/bun": "catalog:",
		"@url-shortener/config": "workspace:*",
		"tsdown": "^0.16.5",
		"typescript": "catalog:"
	}
}
