{
	"name": "analytics",
	"type": "module",
	"main": "src/index.ts",
	"scripts": {
		"build": "tsdown",
		"check-types": "tsc -b",
		"compile": "bun build --compile --minify --sourcemap --bytecode ./src/index.ts --outfile analytics",
		"dev": "bun --port=3002 run --hot src/index.ts",
		"start": "bun run dist/index.mjs"
	},
	"dependencies": {
		"@orpc/openapi": "catalog:",
		"@orpc/server": "catalog:",
		"@orpc/zod": "catalog:",
		"@url-shortener/api": "workspace:*",
		"@url-shortener/auth": "workspace:*",
		"@url-shortener/db": "workspace:*",
		"@url-shortener/env": "workspace:*",
		"amqplib": "^0.10.9",
		"better-auth": "catalog:",
		"dotenv": "catalog:",
		"drizzle-orm": "^0.45.1",
		"hono": "catalog:",
		"isbot": "^5.1.34",
		"ua-parser-js": "^2.0.9",
		"zod": "catalog:"
	},
	"devDependencies": {
		"@types/bun": "catalog:",
		"@url-shortener/config": "workspace:*",
		"tsdown": "^0.16.5",
		"typescript": "catalog:"
	}
}
