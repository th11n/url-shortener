{
	"name": "server",
	"type": "module",
	"main": "src/index.ts",
	"scripts": {
		"build": "tsdown",
		"check-types": "tsc -b",
		"compile": "bun build --compile --minify --sourcemap --bytecode ./src/index.ts --outfile server",
		"dev": "bun run --hot src/index.ts",
		"start": "bun run dist/index.mjs"
	},
	"dependencies": {
		"@orpc/openapi": "catalog:",
		"@orpc/server": "catalog:",
		"@orpc/zod": "catalog:",
		"@url-shortener/api": "workspace:*",
		"@url-shortener/auth": "workspace:*",
		"@url-shortener/db": "workspace:*",
		"@url-shortener/env": "workspace:*",
		"better-auth": "catalog:",
		"dotenv": "catalog:",
		"hono": "catalog:",
		"pg": "^8.18.0",
		"zod": "catalog:"
	},
	"devDependencies": {
		"@types/bun": "catalog:",
		"@types/pg": "^8.16.0",
		"@url-shortener/config": "workspace:*",
		"tsdown": "^0.16.5",
		"typescript": "catalog:"
	}
}
